# Contact form configuration
# Option 1: Custom endpoint
# NEXT_PUBLIC_CONTACT_ENDPOINT=https://your-api.example.com/contact

# Option 2: FormSubmit mailbox delivery (good for static hosting)
# If NEXT_PUBLIC_CONTACT_MAILBOX is omitted, app falls back to siteConfig.email
NEXT_PUBLIC_CONTACT_PROVIDER=formsubmit
NEXT_PUBLIC_CONTACT_MAILBOX=you@yourdomain.com
